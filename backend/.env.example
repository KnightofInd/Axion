# App
APP_NAME=AXION API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Backend auth for sidebar/dashboard -> FastAPI
AXION_INTERNAL_API_KEY=replace-me

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_DB_SCHEMA=public

# Google OAuth (web app credentials)
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# GCP + AI
GOOGLE_CLOUD_PROJECT=axion-prod
GOOGLE_CLOUD_REGION=us-central1
GEMINI_API_KEY=
GEMINI_FALLBACK_MODELS=gemini-1.5-pro,gemini-1.5-flash
VERTEX_EMBEDDING_MODEL=text-embedding-005
GEMINI_FLASH_MODEL=gemini-2.0-flash
GEMINI_PRO_MODEL=gemini-1.5-pro

# Optional local dev toggles
ALLOW_ORIGIN=http://localhost:3000
